@using SecureShield.Application.Services
@inject ILocalizationService L

<section id="training" class="section-pad section-dark">
    <div class="container-pad">
        <div class="row g-5">
            <div class="col-lg-4" data-reveal-left>
                <div class="heading-label"><span class="label-line"></span><span class="label-text">@L["training.label"]</span></div>
                <h2 class="heading-title" style="margin-top: 14px;">@L["training.title"]</h2>
                <div class="heading-divider"></div>
                <p class="heading-sub">@L["training.sub"]</p>
                <div style="margin-top: 32px; display: flex; flex-direction: column; gap: 14px;">
                    @for (var i = 1; i <= 3; i++) { var idx = i;
                        <div style="display: flex; gap: 14px; padding: 16px 18px; background: rgba(255,255,255,0.04); border-radius: 12px; border: 1px solid rgba(200,162,58,0.15);">
                            <div style="width: 44px; height: 44px; border-radius: 10px; background: rgba(200,162,58,0.1); color: var(--gold); display: flex; align-items: center; justify-content: center; font-size: 18px;">@(new[] { "⏱️", "🏆", "🎓" }[idx - 1])</div>
                            <div>
                                <div style="font-family: var(--font-head); font-weight: 700; color: white; font-size: 16px;">@L[$"training.stat{idx}.value"]</div>
                                <div style="font-size: 12px; color: rgba(255,255,255,0.6);">@L[$"training.stat{idx}.label"]</div>
                            </div>
                        </div>
                    }
                </div>
            </div>
            <div class="col-lg-8">
                <div class="grid-2" data-reveal>
                    @for (var i = 1; i <= 7; i++) { var num = i.ToString("00"); var idx = i;
                        <article style="background: rgba(255,255,255,0.04); border: 1px solid rgba(200,162,58,0.2); border-radius: 12px; padding: 24px; height: 100%;">
                            <div style="display: flex; align-items: center; gap: 14px;">
                                <div style="width: 44px; height: 44px; border-radius: 10px; background: rgba(200,162,58,0.1); color: var(--gold); display: flex; align-items: center; justify-content: center; font-size: 20px;">@(new[] { "💪", "🔥", "⚠️", "🎧", "❤️", "👥", "📋" }[idx - 1])</div>
                                <span style="font-family: var(--font-head); font-size: 28px; font-weight: 800; color: rgba(200,162,58,0.4);">@num</span>
                            </div>
                            <h3 style="color: white; font-size: 17px; margin: 16px 0 8px;">@L[$"training.module{idx}.title"]</h3>
                            <p style="font-size: 13px; color: rgba(255,255,255,0.6); line-height: 1.6; margin: 0;">@L[$"training.module{idx}.desc"]</p>
                        </article>
                    }
                </div>
            </div>
        </div>
    </div>
</section>
