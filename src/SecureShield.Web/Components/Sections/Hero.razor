@using SecureShield.Application.Services
@inject ILocalizationService L

<section id="home" class="hero">
    <div class="hero-bg">
        <img src="/images/hero-bg.jpg" alt="Professional Bangladeshi security guards standing in formation" />
    </div>
    <div class="hero-overlay"></div>
    <div class="container-pad hero-content">
        <div class="hero-eyebrow"><span class="dot"></span> @L["hero.eyebrow"]</div>
        <h1>@L["hero.title1"]<br /><span class="gold">@L["hero.title2"]</span></h1>
        <div class="divider"></div>
        <p class="subhead">@L["hero.subhead"]</p>
        <div class="hero-ctas">
            <a href="#contact" class="btn-gold">@L["hero.ctaQuote"]</a>
            <a href="#contact" class="btn-outline-gold">@L["hero.ctaContact"]</a>
            <a href="tel:+8801700000000" class="btn-black">@L["hero.ctaCall"]</a>
        </div>
        <div class="hero-trust">
            <div class="item"><span class="gold-text">⭐⭐⭐⭐⭐</span> @L["hero.trust1"]</div>
            <div class="item">🛡️ @L["hero.trust2"]</div>
            <div class="item">👥 @L["hero.trust3"]</div>
            <div class="item">🗺️ @L["hero.trust4"]</div>
        </div>
    </div>
</section>
