@using SecureShield.Application.Interfaces
@using SecureShield.Application.Services
@inject IClientRepository Clientss
@inject ITestimonialRepository Testimonials
@inject ILocalizationService L

<section id="public-clients" class="section-pad" style="background: var(--bg);">
    <div class="container-pad">
        <div class="section-heading" style="text-align: center; max-width: 760px; margin: 0 auto 60px;" data-reveal>
            <div class="heading-label center"><span class="label-line"></span><span class="label-text">@L["clients.label"]</span><span class="label-line"></span></div>
            <h2 class="heading-title">@L["clients.title"]</h2>
            <p class="heading-sub" style="margin-left: auto; margin-right: auto;">@L["clients.sub"]</p>
            <div class="heading-divider center"></div>
        </div>
        <div class="marquee-container" data-reveal>
            <div class="marquee">
                @foreach (var c in _clients.Concat(_clients)) {
                    <div class="marquee-item"><span class="ico">🏢</span><span class="logo-text">@c.Logo</span></div>
                }
            </div>
        </div>
        <div style="margin-top: 80px; text-align: center;" data-reveal>
            <div class="heading-label center" style="margin-bottom: 16px;"><span class="label-line"></span><span class="label-text">@L["clients.testimonialLabel"]</span><span class="label-line"></span></div>
            <h3 class="heading-title" style="font-size: 28px;">@L["clients.testimonialTitle"]</h3>
        </div>
        <div style="margin-top: 48px; max-width: 820px; margin-left: auto; margin-right: auto;" data-reveal>
            <div class="testimonial-card">
                <div class="testimonial-quote">"</div>
                @if (_current != null) {
                    <div class="testimonial-stars">@(new string('⭐', _current.Rating))</div>
                    <p class="testimonial-text">"@_current.Message"</p>
                    <div class="testimonial-author">
                        <div class="testimonial-avatar">@_current.Name[0]</div>
                        <div><div class="testimonial-name">@_current.Name</div><div class="testimonial-role">@_current.Role, @_current.Company</div></div>
                    </div>
                }
            </div>
            <div style="margin-top: 24px; display: flex; justify-content: center; gap: 10px;">
                @for (var i = 0; i < _testimonials.Count; i++) {
                    <button @onclick="() => SetTestimonial(i)" style="height: 8px; border-radius: 4px; border: none; cursor: pointer; background: @(i == _idx ? "var(--gold)" : "rgba(17,17,17,0.2)"); width: @(i == _idx ? "32px" : "8px");"></button>
                }
            </div>
        </div>
    </div>
</section>

@code {
    private List<SecureShield.Domain.Entities.Client> _clients = new();
    private List<SecureShield.Domain.Entities.Testimonial> _testimonials = new();
    private SecureShield.Domain.Entities.Testimonial? _current;
    private int _idx;
    protected override async Task OnInitializedAsync() {
        _clients = (await Clientss.GetAllAsync()).ToList();
        _testimonials = (await Testimonials.GetPublishedAsync()).ToList();
        if (_testimonials.Any()) _current = _testimonials[0];
    }
    private void SetTestimonial(int i) { _idx = i; if (i < _testimonials.Count) _current = _testimonials[i]; }
}
