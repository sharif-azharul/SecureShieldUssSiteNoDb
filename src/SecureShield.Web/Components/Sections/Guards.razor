@using SecureShield.Application.Interfaces
@using SecureShield.Application.Services
@inject IGuardRepository Guardss
@inject ILocalizationService L

<section id="public-guards" class="section-pad">
    <div class="container-pad">
        <div class="section-heading" style="text-align: center; max-width: 760px; margin: 0 auto 60px;" data-reveal>
            <div class="heading-label center"><span class="label-line"></span><span class="label-text">@L["guards.label"]</span><span class="label-line"></span></div>
            <h2 class="heading-title">@L["guards.title"]</h2>
            <p class="heading-sub" style="margin-left: auto; margin-right: auto;">@L["guards.sub"]</p>
            <div class="heading-divider center"></div>
        </div>
        <div class="filter-tabs" data-reveal>
            @foreach (var c in _categories) {
                <button class="filter-tab @(c.Id == _active ? "active" : "")" @onclick="() => SetFilter(c.Id)">@L[c.LabelKey]</button>
            }
        </div>
        <div class="guards-grid" data-reveal>
            @foreach (var g in _filtered) {
                <article class="guard-card">
                    <img src="@g.ImageUrl" alt="@g.Name" loading="lazy" />
                    <div class="guard-badge">🛡️</div>
                    <div class="guard-info">
                        <div style="color: var(--gold); font-size: 12px;">⭐⭐⭐⭐⭐</div>
                        <h3>@g.Name</h3>
                        <p class="role">@g.Role</p>
                    </div>
                </article>
            }
        </div>
    </div>
</section>

@code {
    private List<SecureShield.Domain.Entities.GuardProfile> _all = new();
    private List<SecureShield.Domain.Entities.GuardProfile> _filtered = new();
    private string _active = "all";
    private readonly List<(string Id, string LabelKey)> _categories = new() {
        ("all", "guards.filterAll"), ("male", "guards.filterMale"), ("female", "guards.filterFemale"),
        ("armed", "guards.filterArmed"), ("vip", "guards.filterVip"), ("supervisor", "guards.filterSupervisor"),
    };
    protected override async Task OnInitializedAsync() { _all = (await Guardss.GetAllAsync()).ToList(); _filtered = _all; }
    private void SetFilter(string id) { _active = id; _filtered = id == "all" ? _all : _all.Where(g => g.Category == id).ToList(); }
}
