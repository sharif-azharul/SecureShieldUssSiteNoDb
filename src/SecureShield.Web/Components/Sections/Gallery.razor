@using SecureShield.Application.Interfaces
@using SecureShield.Application.Services
@inject IGalleryRepository Galleryss
@inject ILocalizationService L

<section id="gallery" class="section-pad">
    <div class="container-pad">
        <div class="section-heading" style="text-align: center; max-width: 760px; margin: 0 auto 60px;" data-reveal>
            <div class="heading-label center"><span class="label-line"></span><span class="label-text">@L["gallery.label"]</span><span class="label-line"></span></div>
            <h2 class="heading-title">@L["gallery.title"]</h2>
            <p class="heading-sub" style="margin-left: auto; margin-right: auto;">@L["gallery.sub"]</p>
            <div class="heading-divider center"></div>
        </div>
        <div class="filter-tabs" data-reveal>
            @foreach (var c in _categories) {
                <button class="filter-tab active-gold @(c.Id == _active ? "active-gold" : "")" @onclick="() => SetFilter(c.Id)">@L[c.LabelKey]</button>
            }
        </div>
        <div class="gallery-grid" data-reveal>
            @foreach (var g in _filtered) {
                <div class="gallery-item">
                    <img src="@g.ImageUrl" alt="@g.Title" loading="lazy" />
                    <div class="gallery-overlay">
                        <div class="gallery-cat">@GetCatLabel(g.Category)</div>
                        <div class="gallery-title">@g.Title</div>
                        @if (!string.IsNullOrEmpty(g.Caption)) { <div class="gallery-cap">@g.Caption</div> }
                    </div>
                </div>
            }
        </div>
    </div>
</section>

@code {
    private List<SecureShield.Domain.Entities.GalleryItem> _all = new();
    private List<SecureShield.Domain.Entities.GalleryItem> _filtered = new();
    private string _active = "all";
    private readonly List<(string Id, string LabelKey)> _categories = new() {
        ("all", "gallery.filterAll"), ("duty", "gallery.filterDuty"), ("training", "gallery.filterTraining"),
        ("events", "gallery.filterEvents"), ("office", "gallery.filterOffice"),
    };
    protected override async Task OnInitializedAsync() { _all = (await Galleryss.GetAllAsync()).ToList(); _filtered = _all; }
    private void SetFilter(string id) { _active = id; _filtered = id == "all" ? _all : _all.Where(g => g.Category == id).ToList(); }
    private string GetCatLabel(string c) => c switch { "duty" => L["gallery.catDuty"], "training" => L["gallery.catTraining"], "events" => L["gallery.catEvents"], "office" => L["gallery.catOffice"], _ => c.ToUpper() };
}
