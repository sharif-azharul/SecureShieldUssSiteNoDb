@using SecureShield.Application.Services
@inject ILocalizationService L

<section id="why" class="section-pad" style="background: var(--bg);">
    <div class="container-pad">
        <div class="section-heading" style="text-align: center; max-width: 760px; margin: 0 auto 60px;" data-reveal>
            <div class="heading-label center"><span class="label-line"></span><span class="label-text">@L["why.label"]</span><span class="label-line"></span></div>
            <h2 class="heading-title">@L["why.title"]</h2>
            <p class="heading-sub" style="margin-left: auto; margin-right: auto;">@L["why.sub"]</p>
            <div class="heading-divider center"></div>
        </div>
        <div class="grid-4" data-reveal>
            @for (var i = 1; i <= 8; i++) { var idx = i;
                <article class="card-premium" style="text-align: center;">
                    <div class="card-icon-gold" style="margin: 0 auto; width: 64px; height: 64px; font-size: 28px;">@(new[] { "⏰", "✅", "👥", "📄", "🎓", "🚨", "💰", "🗺️" }[idx - 1])</div>
                    <h3 class="card-title" style="margin-top: 24px;">@L[$"why.item{idx}.title"]</h3>
                    <p class="card-desc">@L[$"why.item{idx}.desc"]</p>
                </article>
            }
        </div>
    </div>
</section>
