@page "/admin/login"
@layout LoginLayout
@using Microsoft.AspNetCore.Components.Forms
@using SecureShield.Application.DTOs
@using SecureShield.Application.Services
@inject IAdminAuthService AuthService
@inject NavigationManager Nav

<div style="text-align: center; margin-bottom: 32px;">
    <img src="/uss-logo.svg" alt="USS Security Services Ltd." style="height: 56px; filter: brightness(0) invert(1); margin: 0 auto;" />
    <h1 style="color: white; font-family: var(--font-head); font-size: 24px; font-weight: 700; margin: 24px 0 6px;">Admin Login</h1>
    <p style="color: rgba(255,255,255,0.6); font-size: 14px;">Secure admin access — USS Security Services Ltd.</p>
</div>

<div style="background: white; padding: 32px; border-radius: 16px; box-shadow: 0 16px 48px rgba(0,0,0,0.4); border-top: 4px solid var(--gold);">
    <EditForm Model="@_model" OnValidSubmit="@Loginss">
        <DataAnnotationsValidator />
        <div style="margin-bottom: 16px;">
            <label class="form-label">Email</label>
            <input class="form-input" @bind="_model.Email" placeholder="admin@uss-security.com.bd" style="width: 100%; padding: 14px 18px; border: 1.5px solid #ECE8D9; border-radius: 10px; font-size: 14px;" />
        </div>
        <div style="margin-bottom: 24px;">
            <label class="form-label">Password</label>
            <input type="password" class="form-input" @bind="_model.Password" placeholder="••••••••" style="width: 100%; padding: 14px 18px; border: 1.5px solid #ECE8D9; border-radius: 10px; font-size: 14px;" />
        </div>
        <button type="submit" class="btn-gold" style="width: 100%; justify-content: center; padding: 14px;" disabled="@_loading">
            @(_loading ? "Signing in..." : "Sign In →")
        </button>
    </EditForm>

    @if (_hasError)
    {
        <div style="margin-top: 16px; padding: 12px 16px; background: rgba(198,40,40,0.1); border-left: 3px solid #C62828; border-radius: 8px; color: #C62828; font-size: 14px;">
            @_error
        </div>
    }

    <div style="margin-top: 24px; text-align: center; padding: 14px; background: #F7F7F5; border-radius: 10px;">
        <div style="font-family: var(--font-head); font-size: 11px; font-weight: 700; color: #111111; text-transform: uppercase; letter-spacing: 1.5px;">Demo Credentials</div>
        <div style="font-size: 13px; color: #6B6B6B; margin-top: 6px;">admin@uss-security.com.bd</div>
        <div style="font-size: 13px; color: #6B6B6B;">Admin@123</div>
    </div>
</div>

@code {
    private LoginDto _model = new("admin@uss-security.com.bd", "Admin@123");
    private bool _loading;
    private bool _hasError;
    private string? _error;

    private async Task Loginss()
    {
        _loading = true;
        _hasError = false;
        try
        {
            var token = await AuthService.AuthenticateAsync(_model.Email, _model.Password);
            if (string.IsNullOrEmpty(token))
            {
                _hasError = true;
                _error = "Invalid email or password";
            }
            else
            {
                Nav.NavigateTo("/admin/dashboard?token=" + Uri.EscapeDataString(token), forceLoad: true);
            }
        }
        catch (Exception ex)
        {
            _hasError = true;
            _error = "Login failed: " + ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }
}
