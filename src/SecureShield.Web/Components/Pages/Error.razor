@page "/error"
@layout MainLayout

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-12 text-center">
    <MudText Typo="Typo.h1" Style="color: #0B1F3A; font-weight: 800;">500</MudText>
    <MudText Typo="Typo.h5" Style="color: #0B1F3A;">Something went wrong.</MudText>
    <MudText Typo="Typo.body1" Color="Color.Surface" Class="mt-2">
        An error occurred while processing your request. Please try again later.
    </MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/" Class="mt-4"
               Style="background: #0B1F3A; color: white; border-radius: 24px;">
        Back to Home
    </MudButton>
</MudContainer>
