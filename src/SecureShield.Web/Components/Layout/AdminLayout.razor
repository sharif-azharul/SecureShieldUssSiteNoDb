@inherits LayoutComponentBase
@using MudBlazor
@inject NavigationManager Nav

<MudThemeProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="2" Style="background: #111111; color: #C8A23A;">
        <img src="/uss-logo.svg" alt="USS" style="height: 36px; filter: brightness(0) invert(1); margin-right: 12px;" />
        <MudText Typo="Typo.h6" Style="color: #C8A23A; font-weight: 700; margin-left: 4px; font-family: Poppins, sans-serif;">
            USS Admin
        </MudText>
        <MudSpacer />
        <MudButton Variant="Variant.Text" OnClick="@BackToSite" Color="Color.Primary">
            <MudIcon Icon="@Icons.Material.Filled.OpenInNew" Class="mr-2" /> Back to Site
        </MudButton>
        <MudButton Variant="Variant.Filled" OnClick="@Logout" Style="background: #D32F2F; color: white;">
            <MudIcon Icon="@Icons.Material.Filled.Logout" Class="mr-2" /> Logout
        </MudButton>
    </MudAppBar>

    <MudDrawer Fixed="true" Elevation="2">
        <MudNavMenu>
            <MudNavLink Href="/admin/dashboard" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
            <MudNavLink Href="/admin/careers" Icon="@Icons.Material.Filled.Work">Career Applications</MudNavLink>
            <MudNavLink Href="/admin/messages" Icon="@Icons.Material.Filled.Mail">Contact Messages</MudNavLink>
            <MudNavLink Href="/admin/services" Icon="@Icons.Material.Filled.Shield">Manage Services</MudNavLink>
            <MudNavLink Href="/admin/clients" Icon="@Icons.Material.Filled.Apartment">Manage Clients</MudNavLink>
            <MudNavLink Href="/admin/guards" Icon="@Icons.Material.Filled.People">Manage Guards</MudNavLink>
            <MudNavLink Href="/admin/gallery" Icon="@Icons.Material.Filled.PhotoLibrary">Manage Gallery</MudNavLink>
            <MudNavLink Href="/admin/testimonials" Icon="@Icons.Material.Filled.FormatQuote">Manage Testimonials</MudNavLink>
            <MudNavLink Href="/admin/settings" Icon="@Icons.Material.Filled.Settings">Website Settings</MudNavLink>
            <MudNavLink Href="/admin/seo" Icon="@Icons.Material.Filled.Search">SEO Settings</MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent Class="pa-8" Style="background: #F8F9FA;">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private void BackToSite() => Nav.NavigateTo("/", forceLoad: true);
    private void Logout() => Nav.NavigateTo("/admin/login", forceLoad: true);
}
